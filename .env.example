# =============================================================================
# Alpaca Trading Bot - Environment Configuration Example
# =============================================================================
# Copy this file to `.env` in the repository root and fill in real values.
# NEVER commit the populated .env file. The .gitignore is configured to
# exclude it, but verify before pushing.
# =============================================================================

# --- Alpaca Credentials (PAPER) ---
ALPACA_API_KEY=PKXWFBI4FKKEMBRB7W7JXTBX1H
ALPACA_API_SECRET=5B6J7v3Fzx1eoBGDef9EgNR4x8RgTJTdkZNv
ALPACA_ENV=paper
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_FEED=auto

# -----------------------------------------------------------------------------
# Master safety switches
# -----------------------------------------------------------------------------
# Master kill: must be true before any real orders are submitted.
LIVE_TRADING_ENABLED=false

# When true, all logic runs but no orders are sent to Alpaca.
DRY_RUN=true

# Required confirmation phrase when ALPACA_ENV=live AND LIVE_TRADING_ENABLED=true.
# The exact value must be `yes_i_understand` to enable live order submission.
CONFIRM_LIVE_TRADING=

# -----------------------------------------------------------------------------
# Logging and storage
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_DIR=./logs
STATE_DIR=./runtime

# -----------------------------------------------------------------------------
# Heartbeat and orchestration
# -----------------------------------------------------------------------------
HEARTBEAT_INTERVAL_SECONDS=60
ORCHESTRATOR_TICK_SECONDS=15

# When > 0, heartbeat also logs a Markdown table (| Metric | Value |) from the
# same intraday tearsheet parser on this slower cadence. Does not replace
# HEARTBEAT_INTERVAL_SECONDS; structured one-line heartbeat still runs every
# HEARTBEAT_INTERVAL_SECONDS as in Phase 2. Use 3600 for hourly table snapshots,
# or 0 to disable.
HEARTBEAT_TEARSHEET_MARKDOWN_INTERVAL_SECONDS=3600

# -----------------------------------------------------------------------------
# Phase 3: dynamic universe scanner + correlation gate + SPY flash monitor
# -----------------------------------------------------------------------------
# Canary (RUN_LIVE_CANARY_ON_STARTUP / CANARY_*) remains first for live deployments;
# dynamic universe applies only inside the orchestrator after startup flow.
#
# Liquidity-ranked US equity universe (Alpaca Assets + daily bars). On failure or
# empty ranking, SYMBOLS remains the failover basket from settings/logs.
DYNAMIC_UNIVERSE_ENABLED=false
SCANNER_TOP_N=20
SCANNER_VOLUME_LOOKBACK_DAYS=30
SCANNER_MAX_CANDIDATES=500
SCANNER_MIN_HISTORY_DAYS=20
# Eastern time: refresh at or after regular session open gate.
SCANNER_REFRESH_HOUR_ET=9
SCANNER_REFRESH_MINUTE_ET=31

# Block new long follower entries when leader is held long and 1Day closes too
# correlated (calendar-day overlap via Alpaca daily bars — trading days returned).
CORRELATION_BREAKER_ENABLED=true
CORRELATION_LEADER_SYMBOL=SPY
# Comma-separated list; default Nasdaq-beta ETF basket extension point.
CORRELATION_FOLLOWER_SYMBOLS=QQQ
CORRELATION_BREAKER_THRESHOLD=0.85
CORRELATION_LOOKBACK_CALENDAR_DAYS=30

# Global circuit: if BLACK_SWAN_SYMBOL (default SPY) Mid falls >= drop from rolling
# peak within window, emergency flatten + latched kill switch (orchestrator).
BLACK_SWAN_ENABLED=true
BLACK_SWAN_SYMBOL=SPY
BLACK_SWAN_DROP_PCT=0.03
BLACK_SWAN_WINDOW_MINUTES=15

# -----------------------------------------------------------------------------
# Universe and bars
# -----------------------------------------------------------------------------
# Static, conservative ETF basket (broad equities, tech, small caps,
# financials, emerging markets). Override only after verifying live behavior
# with the canary on this default basket.
SYMBOLS=SPY,QQQ,IWM,XLF,EEM

# Bar timeframe for indicator calculations.
# Supported: 1Min, 5Min, 15Min, 1Hour, 1Day
BAR_TIMEFRAME=5Min

# -----------------------------------------------------------------------------
# Strategy parameters (RSI mean reversion)
# -----------------------------------------------------------------------------
RSI_LENGTH=14
RSI_OVERSOLD=30
RSI_EXIT=50
# Volatility-aware RSI entry tiers:
# - atr_pct <= HIGH_VOL_ATR_PCT_THRESHOLD -> DEFAULT_RSI_ENTRY
# - atr_pct  > HIGH_VOL_ATR_PCT_THRESHOLD -> HIGH_VOL_RSI_ENTRY
DEFAULT_RSI_ENTRY=30
HIGH_VOL_RSI_ENTRY=35
HIGH_VOL_ATR_PCT_THRESHOLD=0.05
# ATR-adjusted RSI entry threshold. When enabled:
# threshold = clamp(DYNAMIC_RSI_BASE * ATR(short) / ATR(long), min, max)
DYNAMIC_RSI_ENABLED=false
DYNAMIC_RSI_BASE=30
DYNAMIC_RSI_K=2.0
DYNAMIC_RSI_MIN=20
DYNAMIC_RSI_MAX=35
ATR_LOOKBACK=50
DYNAMIC_RSI_SHORT_ATR=5
DYNAMIC_RSI_LONG_ATR=20
# Optional hybrid VWAP/Bollinger confirmation gates. They may be enabled together.
BOLLINGER_ENABLED=false
BOLLINGER_LENGTH=20
BOLLINGER_STD=2.0
# 0 disables the width check; e.g. 0.02 requires band width >= 2% of basis.
BOLLINGER_MIN_WIDTH_PCT=0.02
# Alias for BOLLINGER_MIN_WIDTH_PCT; 0.02 means 2% BandWidth.
BOLLINGER_BW_MIN=0.02
# When true, Bollinger also requires price <= lower band for long entries.
# When false, Bollinger is a volatility-width gate only.
BOLLINGER_REQUIRE_TOUCH=false
VWAP_STRATEGY_ENABLED=false
VWAP_LENGTH=20
VWAP_STD=2.0
# Long entries require VWAP z-score <= -VWAP_Z_THRESHOLD when VWAP_STRATEGY_ENABLED=true.
VWAP_Z_THRESHOLD=2.0
# ADX regime bands for the hybrid strategy. ADX >= ADX_HIGH requires a 1.5x deeper VWAP z-score.
ADX_LOW=20
ADX_HIGH=40
# Entry time filter in US Eastern time. Exits/risk controls remain active outside this window.
TIME_OF_DAY_FILTER_ENABLED=true
TIME_OF_DAY_TRADE_START=10:00
TIME_OF_DAY_TRADE_END=15:00
# Optional quick-fire mode: bypass SMA filter only when RSI is extremely low.
AGGRESSIVE_MODE=false
AGGRESSIVE_RSI_BYPASS_THRESHOLD=20
# Controlled scale-in (disabled by default):
# - only considered when an existing position is underwater by threshold
# - capped by MAX_BULLETS_PER_SYMBOL and normal risk/compliance gates
SCALE_IN_ENABLED=false
SCALE_IN_UNDERWATER_PCT=-0.03
SCALE_IN_RSI_THRESHOLD=25
SCALE_IN_ADD_QTY=1
MAX_BULLETS_PER_SYMBOL=2
ATR_LENGTH=14
ATR_STOP_MULTIPLIER=2.0
ATR_PROFIT_MULTIPLIER=3.0
MAX_HOLD_BARS=24

# Regime filter (ADX / 200-SMA momentum) + synthetic trailing-profit
ADX_LENGTH=14
# ADX below this level => "Range" regime; used for relaxed RSI entry gating.
ADX_RANGE_MAX=25.0
# Optional alias. If set, overrides ADX_RANGE_MAX.
# ADX_THRESHOLD=25.0
SMA_FILTER_LENGTH=200
SMA_SLOPE_LOOKBACK_BARS=5
# Activate synthetic trailing once unrealized gain >= 1% from entry.
TRAIL_TRIGGER_PCT=0.01
# Floor profit lock at entry * (1 + this) once trailing is active.
TRAIL_LOCKED_PROFIT_PCT=0.005
TRAIL_ATR_MULTIPLIER=1.5
# Position-sizing conviction multipliers when last close is above / below 200 SMA.
HIGH_CONVICTION_RISK_MULTIPLIER=1.5
LOW_CONVICTION_RISK_MULTIPLIER=0.5

# -----------------------------------------------------------------------------
# Trade-level risk
# -----------------------------------------------------------------------------
# Max % of equity risked per trade (1% = 0.01).
MAX_RISK_PER_TRADE_PCT=0.01

# Hard cap (USD) on total notional exposure managed by the bot.
# Default is intentionally tiny to support a canary first deployment.
MAX_EQUITY_USAGE_USD=50
# Optional alias. If >0, this value overrides MAX_EQUITY_USAGE_USD.
MAX_DOLLARS_PER_TRADE=0

# Max gross exposure as a fraction of equity (0.5 = 50%).
MAX_GROSS_EXPOSURE_PCT=0.5

# Max number of simultaneously open positions.
MAX_OPEN_POSITIONS=1
# Sector concentration cap.
MAX_OPEN_POSITIONS_PER_SECTOR=2
# JSON object string for symbol -> sector mapping.
# Extend as your watchlist expands.
SECTOR_MAP_JSON='{"AAPL":"Technology","MSFT":"Technology","NVDA":"Technology","SHOP":"Technology","ABNB":"Consumer Cyclical","MARA":"Crypto / Digital Assets"}'

# The dollar capital base allocated to this bot. When >0 the position sizer
# computes risk_budget against this slice instead of full account equity.
# Set this to your dedicated allocation (e.g. 1/5 of the account). Leaving it
# at 0 makes the bot fall back to min(equity, MAX_EQUITY_USAGE_USD).
BOT_CAPITAL_BASE_USD=0

# -----------------------------------------------------------------------------
# Quote and execution filters
# -----------------------------------------------------------------------------
# Skip trades when (ask-bid)/mid exceeds this fraction (0.0005 = 5 bps).
SPREAD_FILTER_PCT=0.0005
# Optional wider cap for Alpaca quotes labelled feed=iex (IEX NBBO is often wider than SIP).
# Leave unset or empty to use SPREAD_FILTER_PCT for IEX as well. Typical paper/dev: 0.001–0.002 (10–20 bps).
# SPREAD_FILTER_PCT_IEX=
# Elastic spread gate keeps the filter enabled but allows bounded widening.
SPREAD_FILTER_ELASTIC_ENABLED=true
# Absolute hard ceiling after all elastic multipliers.
SPREAD_FILTER_MAX_PCT=0.02
SPREAD_FILTER_IEX_ELASTIC_MULTIPLIER=1.75
SPREAD_FILTER_LOW_PRICE_THRESHOLD=25
SPREAD_FILTER_LOW_PRICE_MULTIPLIER=1.5
SPREAD_FILTER_SPARSE_SIZE_THRESHOLD=5
SPREAD_FILTER_SPARSE_QUOTE_MULTIPLIER=1.25
SPREAD_FILTER_FRESH_QUOTE_MULTIPLIER=1.15
SPREAD_FILTER_FRESH_AGE_FRACTION=0.5

# Quotes older than this many seconds are considered stale.
QUOTE_STALENESS_SECONDS=5
# Skip strategy evaluation when cached bars are older than this threshold.
MAX_STRATEGY_BAR_AGE_SECONDS=900

# Cancel an unfilled limit entry after this many seconds.
ORDER_TIMEOUT_SECONDS=30

# --- Midpoint limit peg (limit at NBBO mid, cancel+replace on timeout) ----------
MIDPOINT_PEG_ENABLED=false
MIDPOINT_PEG_TIMEOUT_SECONDS=30
MIDPOINT_PEG_MAX_CYCLES=5
MIDPOINT_PEG_TAG=midpoint_peg

# --- Global QQQ hourly regime (Bear-Volatile risk-off) -------------------------
QQQ_REGIME_ENABLED=true
REGIME_QQQ_SYMBOL=QQQ
REGIME_ATR_RATIO_THRESHOLD=1.2
REGIME_USE_SMA50=true
REGIME_MAX_EQUITY_REDUCTION=0.5
REGIME_BEAR_VOLATILE_BLOCK_ENTRIES=false
REGIME_ATR_LENGTH=14
REGIME_ATR_MA_LENGTH=50

# --- Orchestrator execution risk (5m ATR trail + bar-count time stop) -----------
EXEC_ATR_TRAIL_ENABLED=true
ATR_TRAIL_MULTIPLIER=2.0
MAX_POSITION_BARS=12

# --- Strategy liquidity gate (vs 20-bar volume MA) ------------------------------
LIQUIDITY_GATE_ENABLED=true
LIQUIDITY_THRESHOLD=0.5

# Emergency-flatten aggressiveness as fraction of mid price (0.001 = 10 bps).
EMERGENCY_AGGRESSIVENESS_PCT=0.0015

# -----------------------------------------------------------------------------
# Retry and rate-limit policy
# -----------------------------------------------------------------------------
RETRY_MAX_ATTEMPTS=5
RETRY_BASE_DELAY_SECONDS=0.5
RETRY_MAX_DELAY_SECONDS=20.0

# -----------------------------------------------------------------------------
# Regulatory mode (FINRA Rule 4210 transition)
# -----------------------------------------------------------------------------
# auto | pdt | intraday_margin
# - "pdt": pre-2026-06-04 conservative behavior
# - "intraday_margin": post-2026-06-04 buying-power-centric behavior
# - "auto": switches at 2026-06-04 America/New_York
REGULATORY_MODE=auto

# When false, the bot never increases trading frequency or relaxes legacy
# day-trade throttles, even after 2026-06-04.
POST_RULE4210_SCALING_ENABLED=false

# -----------------------------------------------------------------------------
# Universe filters
# -----------------------------------------------------------------------------
MIN_PRICE=5.0
MIN_AVG_DOLLAR_VOLUME=20000000

# -----------------------------------------------------------------------------
# Kill switch
# -----------------------------------------------------------------------------
# Trip when equity falls this fraction below the daily start equity baseline.
KILL_SWITCH_DRAWDOWN_PCT=0.05

# -----------------------------------------------------------------------------
# Optional: fractional shares
# -----------------------------------------------------------------------------
ENABLE_FRACTIONAL=true
# Optional alias. If set, overrides ENABLE_FRACTIONAL.
ALLOW_FRACTIONAL=true
# Optional alias. If set, overrides ENABLE_FRACTIONAL.
# FRACTIONAL_TRADING_ENABLED=false
# Minimum fractional quantity accepted when ENABLE_FRACTIONAL=true.
FRACTIONAL_MIN_QTY=0.001
# Minimum quantity accepted by the sizer (1.0 for whole-share trading).
MIN_SHARES=1.0
# Do not submit orders below this notional even if fractional sizing is enabled.
MIN_ORDER_DOLLARS=10

# -----------------------------------------------------------------------------
# Live canary check (one-time per day, before main loop)
# -----------------------------------------------------------------------------
# When true on the live endpoint with LIVE_TRADING_ENABLED=true and
# DRY_RUN=false, the bot performs a single tiny round-trip trade at startup
# to verify credentials, order submission, fills, reconciliation, and clean
# flatten. The canary skips automatically on paper, in dry-run, or if it
# already ran successfully today. The canary aborts startup on any failure.
RUN_LIVE_CANARY_ON_STARTUP=false

# Symbol used for the canary (must be tradable).
CANARY_SYMBOL=XLF

# Notional dollars for the canary trade. If this is below one full share
# price of CANARY_SYMBOL, the canary requires a fractionable asset and a
# broker-supported fractional limit path; otherwise it fails closed.
CANARY_NOTIONAL_USD=10

# Maximum seconds to wait for canary buy fill + sell fill end-to-end.
CANARY_TIMEOUT_SECONDS=60

# Bare filename (under STATE_DIR) where canary success is persisted to
# prevent re-running multiple times in one trading day.
CANARY_PERSIST_FILENAME=canary_state.json

# -----------------------------------------------------------------------------
# Phase 4: sentiment overlay, anti-martingale sizing, SQLite ledger, passive
# joiner (chase-at-bid BUY entries), and Markdown daily reports.
# -----------------------------------------------------------------------------
SENTIMENT_ENABLED=true
SENTIMENT_HEADLINE_LIMIT=10
SENTIMENT_STRONG_NEGATIVE_THRESHOLD=-0.5
SENTIMENT_CACHE_TTL_SECONDS=300
SENTIMENT_STALE_AFTER_SECONDS=1800
# When true, consecutive API failures can mark sentiment as strong_negative.
SENTIMENT_FAIL_CLOSED=false
SENTIMENT_FAIL_CONSECUTIVE_THRESHOLD=3

PASSIVE_JOINER_ENABLED=true
PASSIVE_JOINER_TIMEOUT_SECONDS=15
PASSIVE_JOINER_MAX_ATTEMPTS=3
PASSIVE_JOINER_SIDE_BUY_PRICE=best_bid
PASSIVE_JOINER_REQUIRE_FRESH_QUOTE=true

DATABASE_PATH=./runtime/tradingbot.sqlite3

ANTI_MARTINGALE_ENABLED=true
ANTI_MARTINGALE_LOSS_STREAK=3
ANTI_MARTINGALE_WIN_RECOVERY=2
ANTI_MARTINGALE_DEFENSIVE_MULTIPLIER=0.5
ANTI_MARTINGALE_NORMAL_MULTIPLIER=1.0

REPORTS_DIR=./reports
DAILY_REPORT_ENABLED=true

# Heartbeat tearsheet source: prefer SQLite completed_trades (today ET) or logs.
TEARSHEET_PRIMARY=sqlite

# -----------------------------------------------------------------------------
# Phase 8: Adaptive Brain & Remote Command Center (all default off)
# -----------------------------------------------------------------------------
ENABLE_AUTOTUNE=false
AUTOTUNE_SUNDAY_HOUR_ET=21
AUTOTUNE_LOOKBACK_DAYS=30
AUTOTUNE_MIN_TRADES_PER_CONFIG=10
AUTOTUNE_MAX_DRAWDOWN_ABS=0.45
DYNAMIC_PARAMS_PATH=src/config/dynamic_params.json

ENABLE_ML_FILTER=false
ML_FILTER_THRESHOLD=0.55
MIN_ML_TRAINING_TRADES=50
ML_MAX_TRAINING_TRADES=500
ML_MODEL_PATH=./runtime/models/ml_signal_filter.pkl
ML_MODEL_META_PATH=./runtime/models/ml_signal_filter_meta.json
ML_INFERENCE_RECENT_CONTEXT=100
# If startup training throws: abort process (False) vs continue (True). False = fail closed on operator policy.
ML_ABORT_ON_TRAINING_FAILURE=false
# If True, block new entries when startup training fails (fail closed for entries).
ML_BLOCK_ENTRIES_ON_TRAINING_FAILURE=true

# --- Discord Integration (default off in production templates) ---
ENABLE_DISCORD_BOT=false
# If true, startup aborts when Discord is enabled but first-contact send fails.
REQUIRE_DISCORD_ON_STARTUP=false
# 1. Go to 'Bot' tab in Dev Portal -> Click 'Reset Token' to get this:
DISCORD_BOT_TOKEN=

# 2. Right-click your channel in Discord -> 'Copy channel ID' (developer mode):
DISCORD_CHANNEL_ID=

# 3. Right-click your Discord user -> 'Copy user ID' (comma-separated for multiple operators):
DISCORD_ALLOWED_USER_IDS=

# --- Bot Application Info (optional; slash command registration) ---
DISCORD_APP_ID=
DISCORD_PUBLIC_KEY=
DISCORD_COMMAND_RATE_LIMIT_SECONDS=5

ENABLE_KELLY_SIZING=false
KELLY_LOOKBACK_TRADES=100
KELLY_FRACTION=0.25
KELLY_MIN_TRADES=30
KELLY_MAX_RISK_MULTIPLIER=1.5
KELLY_MIN_RISK_MULTIPLIER=0.25
