# =============================================================================
# Alpaca Trading Bot - Environment Configuration Example
# =============================================================================
# Copy this file to `.env` in the repository root and fill in real values.
# NEVER commit the populated .env file. The .gitignore is configured to
# exclude it, but verify before pushing.
# =============================================================================

# -----------------------------------------------------------------------------
# Alpaca credentials and environment
# -----------------------------------------------------------------------------
# Generate API keys at https://app.alpaca.markets (live) or
# https://app.alpaca.markets/paper/dashboard (paper).
ALPACA_API_KEY=replace_me
ALPACA_API_SECRET=replace_me

# Trading endpoint selection: "paper" or "live"
ALPACA_ENV=paper

# Market data feed: "sip", "iex", or "auto"
# - "sip": full consolidated feed (paid subscription required for live)
# - "iex": free IEX-only feed; spread filtering will run in degraded confidence
# - "auto": resolve to sip when supported, otherwise fall back to iex
ALPACA_FEED=auto

# -----------------------------------------------------------------------------
# Master safety switches
# -----------------------------------------------------------------------------
# Master kill: must be true before any real orders are submitted.
LIVE_TRADING_ENABLED=false

# When true, all logic runs but no orders are sent to Alpaca.
DRY_RUN=true

# Required confirmation phrase when ALPACA_ENV=live AND LIVE_TRADING_ENABLED=true.
# The exact value must be `yes_i_understand` to enable live order submission.
CONFIRM_LIVE_TRADING=

# -----------------------------------------------------------------------------
# Logging and storage
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_DIR=./logs
STATE_DIR=./runtime

# -----------------------------------------------------------------------------
# Heartbeat and orchestration
# -----------------------------------------------------------------------------
HEARTBEAT_INTERVAL_SECONDS=60
ORCHESTRATOR_TICK_SECONDS=15

# -----------------------------------------------------------------------------
# Universe and bars
# -----------------------------------------------------------------------------
# Static, conservative ETF basket (broad equities, tech, small caps,
# financials, emerging markets). Override only after verifying live behavior
# with the canary on this default basket.
SYMBOLS=SPY,QQQ,IWM,XLF,EEM

# Bar timeframe for indicator calculations.
# Supported: 1Min, 5Min, 15Min, 1Hour, 1Day
BAR_TIMEFRAME=5Min

# -----------------------------------------------------------------------------
# Strategy parameters (RSI mean reversion)
# -----------------------------------------------------------------------------
RSI_LENGTH=14
RSI_OVERSOLD=30
RSI_EXIT=50
ATR_LENGTH=14
ATR_STOP_MULTIPLIER=2.0
ATR_PROFIT_MULTIPLIER=3.0
MAX_HOLD_BARS=24

# -----------------------------------------------------------------------------
# Trade-level risk
# -----------------------------------------------------------------------------
# Max % of equity risked per trade (1% = 0.01).
MAX_RISK_PER_TRADE_PCT=0.01

# Hard cap (USD) on total notional exposure managed by the bot.
# Default is intentionally tiny to support a canary first deployment.
MAX_EQUITY_USAGE_USD=50

# Max gross exposure as a fraction of equity (0.5 = 50%).
MAX_GROSS_EXPOSURE_PCT=0.5

# Max number of simultaneously open positions.
MAX_OPEN_POSITIONS=1

# The dollar capital base allocated to this bot. When >0 the position sizer
# computes risk_budget against this slice instead of full account equity.
# Set this to your dedicated allocation (e.g. 1/5 of the account). Leaving it
# at 0 makes the bot fall back to min(equity, MAX_EQUITY_USAGE_USD).
BOT_CAPITAL_BASE_USD=0

# -----------------------------------------------------------------------------
# Quote and execution filters
# -----------------------------------------------------------------------------
# Skip trades when (ask-bid)/mid exceeds this fraction (0.0005 = 5 bps).
SPREAD_FILTER_PCT=0.0005

# Quotes older than this many seconds are considered stale.
QUOTE_STALENESS_SECONDS=5

# Cancel an unfilled limit entry after this many seconds.
ORDER_TIMEOUT_SECONDS=30

# Emergency-flatten aggressiveness as fraction of mid price (0.001 = 10 bps).
EMERGENCY_AGGRESSIVENESS_PCT=0.0015

# -----------------------------------------------------------------------------
# Retry and rate-limit policy
# -----------------------------------------------------------------------------
RETRY_MAX_ATTEMPTS=5
RETRY_BASE_DELAY_SECONDS=0.5
RETRY_MAX_DELAY_SECONDS=20.0

# -----------------------------------------------------------------------------
# Regulatory mode (FINRA Rule 4210 transition)
# -----------------------------------------------------------------------------
# auto | pdt | intraday_margin
# - "pdt": pre-2026-06-04 conservative behavior
# - "intraday_margin": post-2026-06-04 buying-power-centric behavior
# - "auto": switches at 2026-06-04 America/New_York
REGULATORY_MODE=auto

# When false, the bot never increases trading frequency or relaxes legacy
# day-trade throttles, even after 2026-06-04.
POST_RULE4210_SCALING_ENABLED=false

# -----------------------------------------------------------------------------
# Universe filters
# -----------------------------------------------------------------------------
MIN_PRICE=5.0
MIN_AVG_DOLLAR_VOLUME=20000000

# -----------------------------------------------------------------------------
# Kill switch
# -----------------------------------------------------------------------------
# Trip when equity falls this fraction below the daily start equity baseline.
KILL_SWITCH_DRAWDOWN_PCT=0.05

# -----------------------------------------------------------------------------
# Optional: fractional shares
# -----------------------------------------------------------------------------
ENABLE_FRACTIONAL=false

# -----------------------------------------------------------------------------
# Live canary check (one-time per day, before main loop)
# -----------------------------------------------------------------------------
# When true on the live endpoint with LIVE_TRADING_ENABLED=true and
# DRY_RUN=false, the bot performs a single tiny round-trip trade at startup
# to verify credentials, order submission, fills, reconciliation, and clean
# flatten. The canary skips automatically on paper, in dry-run, or if it
# already ran successfully today. The canary aborts startup on any failure.
RUN_LIVE_CANARY_ON_STARTUP=false

# Symbol used for the canary (must be tradable).
CANARY_SYMBOL=XLF

# Notional dollars for the canary trade. If this is below one full share
# price of CANARY_SYMBOL, the canary requires a fractionable asset and a
# broker-supported fractional limit path; otherwise it fails closed.
CANARY_NOTIONAL_USD=10

# Maximum seconds to wait for canary buy fill + sell fill end-to-end.
CANARY_TIMEOUT_SECONDS=60

# Bare filename (under STATE_DIR) where canary success is persisted to
# prevent re-running multiple times in one trading day.
CANARY_PERSIST_FILENAME=canary_state.json
